# ─── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ADMIN_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# ─── PostgreSQL ───────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5433
PG_USER=gateway
PG_PASSWORD=gateway_secret
PG_DATABASE=api_gateway

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_FAIL_MODE=open

# ─── Batch Writer ─────────────────────────────────────────────────────
BATCH_FLUSH_INTERVAL_MS=5000
BATCH_MAX_SIZE=100

# ─── Upstream (fallback) ──────────────────────────────────────────────
DEFAULT_UPSTREAM_URL=https://url-shortener.up.railway.app
